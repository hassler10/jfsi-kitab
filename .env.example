# Configuration pour l'authentification OTP (email)
# Utilisez ces variables d'environnement pour connecter un compte SMTP réel.

# Exemple (Gmail) :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=mon.email@gmail.com
# SMTP_PASS=mon_mot_de_passe_app
# MAIL_FROM="JFSI <mon.email@gmail.com>"

# Serveur (port)
PORT=3000

# Clé de session (changez pour la production)
SESSION_SECRET=modifiez-moi-pour-la-prod

# Base de données (SQLite par défaut, ou MySQL/Postgres)
# DB_TYPE=sqlite  # ou mysql, postgres
# DB_PATH=./data/jfsi.db  # pour SQLite
# DB_HOST=localhost  # pour MySQL/Postgres
# DB_USER=root
# DB_PASS=password
# DB_NAME=jfsi

# Stripe (paiements)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # pour les webhooks (optionnel)

# Prix des abonnements (en centimes)
PREMIUM_PRICE_ID=price_...  # ID du prix Stripe pour abonnement premium
