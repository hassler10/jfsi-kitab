# ══════════════════════════════════════════════════════════════════
# JFSI — Environment Configuration (Development)
# ══════════════════════════════════════════════════════════════════
# IMPORTANT: Ne jamais pousser ce fichier vers Git!
#            Pour production: utiliser .env.production ou variables Render

# ───────────────────────────────────────────────────────────────────
# 🟢 SERVER
# ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ───────────────────────────────────────────────────────────────────
# 🟢 DATABASE (SQLite — local development)
# ───────────────────────────────────────────────────────────────────
DB_TYPE=sqlite
DB_PATH=./data/jfsi.db

# ───────────────────────────────────────────────────────────────────
# 🟢 SECURITY (Development — Change for production!)
# ───────────────────────────────────────────────────────────────────
SESSION_SECRET=jfsi-dev-session-secret-change-me
OTP_EXPIRY=600

# ───────────────────────────────────────────────────────────────────
# 🟢 STRIPE (Test Keys — Get from https://dashboard.stripe.com)
# ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_
PREMIUM_PRICE_ID=price_

# ───────────────────────────────────────────────────────────────────
# 🟡 EMAIL (Optional — for real OTP delivery)
# ───────────────────────────────────────────────────────────────────
# Uncomment and configure if you want real email OTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM="JFSI <your.email@gmail.com>"

# ───────────────────────────────────────────────────────────────────
# ℹ️ DEVELOPMENT NOTES
# ───────────────────────────────────────────────────────────────────
# 1. OTP code is printed to console (F12 → Console) for testing
# 2. Keep STRIPE keys with "test_" prefix for safe testing
# 3. Admin account: admin@jfsi.local (created by seed.js)
# 4. Database auto-initializes on first run


# === ABONNEMENTS (Prix en centimes) ===
SUBSCRIPTION_PRICE_BASIC=999
SUBSCRIPTION_PRICE_PREMIUM=1999
SUBSCRIPTION_PRICE_ENTERPRISE=4999

# === SÉCURITÉ ===
CORS_ORIGIN=http://localhost:3000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIMER=900000

# === FEATURES ===
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR=false
ENABLE_PAYMENTS=true
ENABLE_ADMIN_PANEL=true

# === URLs ===
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:3000
